{
  "name": "cre-credit-committee",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd apps/api && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "build": "npm run build --workspaces",
    "install:all": "npm install",
    "lint:boundaries": "npm run lint:boundaries:dep-cruiser && npm run lint:boundaries:eslint",
    "lint:boundaries:dep-cruiser": "depcruise --config .dependency-cruiser.cjs apps/api/src",
    "lint:boundaries:eslint": "eslint --config eslint.config.mjs --no-error-on-unmatched-pattern \"apps/api/src/**/*.ts\""
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.5.0",
    "concurrently": "^9.0.0",
    "dependency-cruiser": "^16.4.0",
    "eslint": "^9.10.0",
    "typescript": "^5.5.0"
  }
}
